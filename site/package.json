{
  "name": "@taroify/site",
  "version": "0.9.2",
  "private": true,
  "type": "module",
  "author": "Taroify",
  "keywords": ["rspress", "taro", "components"],
  "scripts": {
    "prepare:docs": "node scripts/prepare-docs.mjs",
    "prepare:theme": "node scripts/build-theme-css.mjs",
    "prepare:site": "npm run prepare:docs && npm run prepare:theme",
    "site:develop": "npm run prepare:site && rspress dev",
    "site:start": "npm run site:develop",
    "site:build": "npm run prepare:site && rspress build",
    "site:preview": "rspress preview",
    "site:serve": "npm run site:preview",
    "site:clean": "node scripts/clean.mjs"
  },
  "dependencies": {
    "@rspress/core": "2.0.18",
    "@rspress/plugin-algolia": "2.0.18",
    "@rspress/plugin-sitemap": "2.0.18",
    "animejs": "4.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "typescript": "^5.9.2"
  }
}
